# Environment Configuration
# Copy this file to .env and fill in your actual values

# Google Gemini API Key (required for CareerBot AI functionality)
# Get your API key from: https://makersuite.google.com/app/apikey
VITE_API_KEY=your_gemini_api_key_here

# Note: This is a client-side Vite app, so env variables must be prefixed with VITE_
# The API key will be exposed in the client - consider using a proxy server for production
